
Require all denied

<FilesMatch "^(dashboard|index|login|auth)\.php$">
    Require all granted
</FilesMatch>

RewriteEngine On
RewriteBase /

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

RewriteRule ^zoqbexowgs/login$ login.php [L]
RewriteRule ^zoqbexowgs/dashboard$ dashboard.php [L]